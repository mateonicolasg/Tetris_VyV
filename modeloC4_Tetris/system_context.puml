@startuml tetris-system-context
title Diagrama de Contexto del Sistema Tetris
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(jugador, "Jugador", "Usuario que interactúa con el videojuego")
System(sistemaTetris, "Sistema de juego Tetris", "Sistema que gestiona la lógica del juego, el tablero, los tetrominos y la puntuación")

Rel(jugador, sistemaTetris, "Inicia partida, mueve y rota tetrominos, consulta el tablero y la puntuación")

@enduml
