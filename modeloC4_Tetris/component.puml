@startuml tetris-component
title Diagrama de Componentes - Motor de Lógica del Sistema Tetris

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Container(ui, "Interfaz de Usuario", , "Muestra el tablero, tetrominos, puntuación, estado del juego y recibe las acciones del jugador")

Container_Boundary(motor_juego_boundary, "Contenedor: Motor de Lógica") {
    
    Component(controlador_juego, "Controlador de Juego", "Controller", "Orquesta el flujo del juego, maneja el bucle principal (Game Loop), pausa, inicio, detención y la lógica de fin de juego")
    
    Component(gestor_tablero, "Gestor de Tablero", "Game Logic Component", "Mantiene la matriz interna de 10x24. Fija piezas en la matriz y procesa la eliminación de filas completamente llenas")
    
    Component(generador_piezas, "Generador de Tetrominos", "Game Logic Component", "Crea la pieza actual con tipo aleatorio y gestiona la siguiente pieza en cola")
    
    Component(gestor_mov_col, "Gestor de Movimiento y Colisiones", "Game Logic Component", "Valida que los desplazamientos y rotaciones de 90° no se solapen con piezas fijadas ni excedan los bordes del tablero. Detecta si una pieza recién colocada en la posición inicial colisiona con bloques existentes (condición de fin de juego)")

    Component(gestor_puntuacion_niveles, "Gestor de Puntuación y Niveles", "Game Logic Component", "Calcula la puntuación basada en líneas eliminadas y actualiza el nivel para ajustar la velocidad del juego")    
}

Rel(ui, controlador_juego, "Envía comandos de entrada (teclado) e instrucciones de control de flujo")
Rel_U(controlador_juego, ui, "Actualiza el estado del juego, tablero, tetrominos y puntuación")

Rel(controlador_juego, gestor_mov_col, "Solicita mover/rotar la pieza actual basándose en el temporizador o input")
Rel(controlador_juego, gestor_mov_col, "Verifica colisión inicial al colocar nueva pieza (detecta fin de juego R16)")
Rel(controlador_juego, generador_piezas, "Solicita una nueva pieza cuando la anterior se fija")
Rel(controlador_juego, gestor_tablero, "Consulta y actualiza el estado del tablero")
Rel(controlador_juego, gestor_puntuacion_niveles, "Solicita reiniciar o consultar puntuación y nivel")

Rel(gestor_mov_col, gestor_tablero, "Consulta el estado de la matriz de 10x24 para verificar colisiones y límites")
Rel(gestor_tablero, gestor_puntuacion_niveles, "Informa cuántas líneas se completaron simultáneamente (1, 2, 3 o 4) para actualizar la puntuación")
Rel(gestor_puntuacion_niveles, controlador_juego, "Notifica cambio de nivel para ajustar la velocidad del juego")

@enduml